@model IEnumerable<UserListViewModel>
@{ ViewData["Title"] = "User Management"; }

<h1 class="mb-3"><i class="bi bi-people-fill"></i> User Management</h1>

<form method="get" class="mb-3">
    <div class="input-group">
        <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Search by email or name..." />
        <button class="btn btn-outline-secondary" type="submit"><i class="bi bi-search"></i> Search</button>
    </div>
</form>

<div class="card">
    <table class="table table-hover mb-0">
        <thead class="table-light">
            <tr>
                <th>Name</th><th>Email</th><th>CPR</th><th>Role</th><th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr><td colspan="5" class="text-center text-muted py-4">No users found.</td></tr>
            }
            @foreach (var u in Model)
            {
                <tr>
                    <td><strong>@u.FullName</strong></td>
                    <td>@u.Email</td>
                    <td><code>@u.CPR</code></td>
                    <td><span class="badge bg-info text-dark">@u.Role</span></td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-primary" asp-action="EditRole" asp-route-id="@u.Id">
                            <i class="bi bi-shield"></i> Change role
                        </a>
                        <form asp-action="Delete" asp-route-id="@u.Id" method="post" class="d-inline"
                              onsubmit="return confirm('Permanently delete @u.Email?')">
                            @Html.AntiForgeryToken()
                            <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
