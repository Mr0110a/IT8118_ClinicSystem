@model IEnumerable<Patient>
@{ ViewData["Title"] = "Patients"; }

<h1 class="mb-3"><i class="bi bi-people"></i> Patients</h1>

<form method="get" class="mb-3">
    <div class="input-group">
        <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Search name or CPR..." />
        <button class="btn btn-outline-secondary" type="submit"><i class="bi bi-search"></i> Search</button>
    </div>
</form>

<div class="card">
    <table class="table table-hover mb-0">
        <thead class="table-light"><tr><th>Name</th><th>CPR</th><th>Phone</th><th>Email</th><th class="text-end">Actions</th></tr></thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr><td colspan="5" class="text-center text-muted py-4">No patients found.</td></tr>
            }
            @foreach (var p in Model)
            {
                <tr>
                    <td><strong>@p.FullName</strong></td>
                    <td><code>@p.CPR</code></td>
                    <td>@p.Phone</td>
                    <td>@p.Email</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Profile" asp-route-id="@p.Id">View profile</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (ViewBag.TotalPages > 1)
{
    <nav class="mt-3"><ul class="pagination justify-content-center">
        @for (int i = 1; i <= ViewBag.TotalPages; i++)
        {
            <li class="page-item @(i == ViewBag.Page ? "active" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-search="@ViewBag.Search">@i</a>
            </li>
        }
    </ul></nav>
}
