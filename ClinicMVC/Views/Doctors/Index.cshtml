@model IEnumerable<Doctor>
@{ ViewData["Title"] = "Doctors"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1><i class="bi bi-person-vcard"></i> Doctors</h1>
    @if (User.IsInRole("ClinicManager"))
    {
        <a class="btn btn-primary" asp-action="Create"><i class="bi bi-plus-lg"></i> Add Doctor</a>
    }
</div>

<form method="get" class="mb-3">
    <div class="input-group">
        <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Search by name or licence number..." />
        <button class="btn btn-outline-secondary" type="submit"><i class="bi bi-search"></i> Search</button>
    </div>
</form>

<div class="card">
    <table class="table table-hover mb-0">
        <thead class="table-light">
            <tr>
                <th>Doctor</th>
                <th>Licence</th>
                <th>Specializations</th>
                <th>Phone</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr><td colspan="5" class="text-center text-muted py-4">No doctors found.</td></tr>
            }
            @foreach (var d in Model)
            {
                <tr>
                    <td><strong>@d.FullName</strong></td>
                    <td><code>@d.LicenseNumber</code></td>
                    <td>
                        @foreach (var s in d.Specializations)
                        {
                            <span class="badge bg-info text-dark me-1">@s.Specialization?.Name</span>
                        }
                    </td>
                    <td>@d.Phone</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@d.Id">View</a>
                        @if (User.IsInRole("ClinicManager"))
                        {
                            <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@d.Id">Edit</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (ViewBag.TotalPages > 1)
{
    <nav class="mt-3"><ul class="pagination justify-content-center">
        @for (int i = 1; i <= ViewBag.TotalPages; i++)
        {
            <li class="page-item @(i == ViewBag.Page ? "active" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-search="@ViewBag.Search">@i</a>
            </li>
        }
    </ul></nav>
}
