@{ ViewData["Title"] = "Doctor Dashboard"; }
<h1 class="mb-4"><i class="bi bi-prescription2"></i> Welcome, Doctor</h1>

<div class="row g-3">
    <div class="col-md-4"><div class="card p-3 text-center">
        <div class="dashboard-stat-label">Appointments today</div>
        <div class="dashboard-stat text-primary">@ViewBag.TodayCount</div>
    </div></div>
    <div class="col-md-8"><div class="card p-3">
        <h5><i class="bi bi-list"></i> Quick links</h5>
        <div class="d-grid gap-2 d-md-flex">
            <a class="btn btn-outline-primary" asp-controller="Appointments" asp-action="Index">My appointments</a>
            <a class="btn btn-outline-primary" asp-controller="LiveBoard" asp-action="Index">Live board</a>
            <a class="btn btn-outline-primary" asp-controller="Patients" asp-action="Index">My patients</a>
        </div>
    </div></div>
</div>
