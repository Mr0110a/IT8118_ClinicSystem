@{ ViewData["Title"] = "Receptionist Dashboard"; }
<h1 class="mb-4"><i class="bi bi-headset"></i> Reception Desk</h1>

<div class="row g-3">
    <div class="col-md-4"><div class="card p-3 text-center">
        <div class="dashboard-stat-label">Today's appointments</div>
        <div class="dashboard-stat text-primary">@ViewBag.TodayAppointments</div>
    </div></div>
    <div class="col-md-4"><div class="card p-3 text-center">
        <div class="dashboard-stat-label">Awaiting confirmation</div>
        <div class="dashboard-stat text-warning">@ViewBag.PendingConfirmations</div>
    </div></div>
    <div class="col-md-4"><div class="card p-3">
        <h5>Quick actions</h5>
        <div class="d-grid gap-2">
            <a class="btn btn-outline-primary" asp-controller="Appointments" asp-action="Book">Book for a patient</a>
            <a class="btn btn-outline-primary" asp-controller="LiveBoard" asp-action="Index">Live board</a>
        </div>
    </div></div>
</div>
