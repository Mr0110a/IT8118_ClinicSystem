@{ ViewData["Title"] = "My Dashboard"; }
<h1 class="mb-4"><i class="bi bi-person-heart"></i> Welcome back!</h1>

<div class="row g-3">
    <div class="col-md-4"><div class="card p-4 h-100 text-center">
        <i class="bi bi-calendar-plus fs-1 text-primary mb-2"></i>
        <h5>Book an appointment</h5>
        <a class="btn btn-primary mt-2" asp-controller="Appointments" asp-action="Book">Book now</a>
    </div></div>
    <div class="col-md-4"><div class="card p-4 h-100 text-center">
        <i class="bi bi-clock-history fs-1 text-success mb-2"></i>
        <h5>My appointments</h5>
        <a class="btn btn-outline-success mt-2" asp-controller="Appointments" asp-action="Index">View list</a>
    </div></div>
    <div class="col-md-4"><div class="card p-4 h-100 text-center">
        <i class="bi bi-file-earmark-medical fs-1 text-info mb-2"></i>
        <h5>My medical records</h5>
        <a class="btn btn-outline-info mt-2" asp-controller="Patients" asp-action="Profile">My profile</a>
    </div></div>
</div>
