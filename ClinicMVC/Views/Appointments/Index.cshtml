@model IEnumerable<Appointment>
@{ ViewData["Title"] = "Appointments"; var statuses = (AppointmentStatus[])ViewBag.Statuses; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1><i class="bi bi-calendar3"></i> Appointments</h1>
    @if (User.IsInRole("Patient") || User.IsInRole("Receptionist"))
    {
        <a class="btn btn-primary" asp-action="Book"><i class="bi bi-plus-lg"></i> Book new</a>
    }
</div>

<form method="get" class="mb-3">
    <div class="input-group">
        <span class="input-group-text">Filter by status</span>
        <select name="status" class="form-select" onchange="this.form.submit()">
            <option value="">All</option>
            @foreach (var s in statuses)
            {
                <option value="@s" selected="@((string?)ViewBag.StatusFilter == s.ToString())">@s</option>
            }
        </select>
    </div>
</form>

<div class="card">
    <table class="table table-hover mb-0 align-middle">
        <thead class="table-light">
            <tr>
                <th>Ref</th><th>When</th><th>Patient</th><th>Doctor</th><th>Status</th><th></th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr><td colspan="6" class="text-center text-muted py-4">No appointments to show.</td></tr>
            }
            @foreach (var a in Model)
            {
                <tr>
                    <td><code>@a.ReferenceCode</code></td>
                    <td>@a.DateTimeStart.ToString("g")</td>
                    <td>@a.Patient?.FullName</td>
                    <td>@a.Doctor?.FullName</td>
                    <td><span class="status-badge status-@a.Status">@a.Status</span></td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@a.Id">View</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (ViewBag.TotalPages > 1)
{
    <nav class="mt-3"><ul class="pagination justify-content-center">
        @for (int i = 1; i <= ViewBag.TotalPages; i++)
        {
            <li class="page-item @(i == ViewBag.Page ? "active" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-status="@ViewBag.StatusFilter">@i</a>
            </li>
        }
    </ul></nav>
}
